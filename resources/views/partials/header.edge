<header>
  <div>
    <div class="site-brand">
      @link({ route: 'home' })
        Pdnode CP Website
      @end
    </div>
    <div>
      <nav>
        @!link({ route: 'about', text: 'About' })
        @if(auth.user)
          @!link({ route: 'cps.index', text: 'Explore' })

          @!avatar({ initials: auth.user.initials })
          @form({ route: 'session.destroy', method: 'POST' })
            @!button({ text: 'Logout' })
          @end
        @else
          @!link({ route: 'new_account.create', text: 'Signup' })
          @!link({ route: 'session.create', text: 'Login' })
        @end
      </nav>
    </div>
  </div>
</header>
